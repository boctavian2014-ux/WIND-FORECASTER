# Copy to .env for local development

# Local Docker Postgres (default in settings)
# DATABASE_URL=postgresql+psycopg://windlab:windlab@localhost:5432/windlab

# Railway / Neon: paste the connection string from the provider UI.
# The app accepts postgres:// or postgresql:// and normalizes to postgresql+psycopg://
# For non-localhost hosts, sslmode=require is appended if missing.
DATABASE_URL=

OPENWEATHER_API_KEY=
